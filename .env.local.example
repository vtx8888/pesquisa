# ============================================================
# Supabase
# ============================================================
# URL do projeto (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Chave anon publica (Settings > API > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
# Chave service_role - SOMENTE servidor, NUNCA expor no client
# Usada nas Server Actions para inserir ignorando RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ============================================================
# Cloudflare Turnstile (anti-bot)
# ============================================================
# Site key (publica) - https://dash.cloudflare.com -> Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
# Secret key (privada) - validacao server-side
TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# ============================================================
# App
# ============================================================
# Titulo exibido na pesquisa
NEXT_PUBLIC_POLL_TITLE=Pesquisa Eleitoral 2026
